<% layout('layouts/boilerplate') %>

<div class="header">
    <a href="/" class="home-link">
        <h1><i class="fas fa-book"></i>Bibliothèque</h1>
    </a>
    <p class="subtitle">A Literary Collection</p>
</div>

<div class="search-section<%= bookInfo ? ' hidden' : '' %>" id="searchSection">
    <form action="/search" method="POST" class="search-form">
        <div class="search-container">
            <input 
                type="text" 
                name="bookName" 
                id="bookName" 
                class="search-input" 
                placeholder="Search for a book..."
                value="<%= searchQuery %>"
                required
            >
            <button type="submit" class="search-button">
                <i class="fas fa-search"></i> Search
            </button>
        </div>
    </form>
</div>

<% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error">
        <i class="fas fa-exclamation-circle"></i>
        <%= error %>
    </div>
<% } %>

<% if (bookInfo) { %>
    <div class="results-section">
        <h2>—</h2>
        <div class="book-info-card">
            <div class="book-content" id="bookContent">
                <%= bookInfo %>
            </div>
        </div>

        <!-- Chat Interface -->
        <div class="chat-section">
            <div class="chat-header">
                <h3>Continue the conversation</h3>
                <p>Ask any follow-up questions about this book</p>
            </div>
            
            <div class="chat-messages" id="chatMessages">
                <!-- Chat messages will appear here -->
            </div>
            
            <div class="chat-input-container">
                <form id="chatForm" class="chat-form">
                    <div class="chat-input-wrapper">
                        <input 
                            type="text" 
                            id="chatInput" 
                            class="chat-input" 
                            placeholder="Ask a question..."
                            autocomplete="off"
                            required
                        >
                        <button type="submit" class="chat-send-button" id="chatSendButton">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="search-again">
            <a href="/" class="btn-search-again">← New Search</a>
        </div>
    </div>

    <script>
        const chatForm = document.getElementById('chatForm');
        const chatInput = document.getElementById('chatInput');
        const chatMessages = document.getElementById('chatMessages');
        const chatSendButton = document.getElementById('chatSendButton');
        const bookName = '<%= bookName || "" %>';

        /**
         * Function to convert GPT-marked book titles to badges
         * This function ONLY processes text marked with [[double brackets]]
         * It does NOT determine what should be badged - that's the AI's responsibility
         * 
         * Rules:
         * - Only converts [[BookTitle]] to badge spans
         * - Preserves all other text as-is
         * - Does NOT add logic for partial titles or context detection
         *   (that must be handled by the AI prompt)
         */
        function addBookNameBadges(text) {
            if (!text) return text;
            
            // Replace [[BookTitle]] markers with badge spans
            // This regex matches double brackets with any content inside
            const regex = /\[\[([^\]]+)\]\]/g;
            
            return text.replace(regex, (match, title) => {
                // Convert the marked title to a badge
                return `<span class="book-name-badge">${title}</span>`;
            });
        }

        // Apply badges to the initial book content
        const bookContent = document.getElementById('bookContent');
        if (bookContent) {
            bookContent.innerHTML = addBookNameBadges(bookContent.textContent);
        }

        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const message = chatInput.value.trim();
            if (!message) return;

            // Add user message to chat with badges
            appendMessage(message, 'user', true);
            chatInput.value = '';
            
            // Disable input while processing
            chatInput.disabled = true;
            chatSendButton.disabled = true;
            
            // Add typing indicator
            const typingId = appendTypingIndicator();

            try {
                const response = await fetch('/chat', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ message })
                });

                const data = await response.json();
                
                // Remove typing indicator
                removeTypingIndicator(typingId);

                if (data.success) {
                    // Add AI response to chat with badges
                    appendMessage(data.response, 'assistant', true);
                } else {
                    appendMessage(data.error || 'An error occurred. Please try again.', 'error');
                }
            } catch (error) {
                removeTypingIndicator(typingId);
                appendMessage('Failed to send message. Please try again.', 'error');
            } finally {
                // Re-enable input
                chatInput.disabled = false;
                chatSendButton.disabled = false;
                chatInput.focus();
            }
        });

        function appendMessage(content, type, applyBadges = false) {
            const messageDiv = document.createElement('div');
            messageDiv.className = `chat-message chat-message-${type}`;
            
            const contentDiv = document.createElement('div');
            contentDiv.className = 'chat-message-content';
            
            if (applyBadges) {
                contentDiv.innerHTML = addBookNameBadges(content);
            } else {
                contentDiv.textContent = content;
            }
            
            messageDiv.appendChild(contentDiv);
            chatMessages.appendChild(messageDiv);
            
            // Scroll to bottom
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        function appendTypingIndicator() {
            const typingDiv = document.createElement('div');
            typingDiv.className = 'chat-message chat-message-assistant typing-indicator';
            typingDiv.id = 'typing-' + Date.now();
            
            const contentDiv = document.createElement('div');
            contentDiv.className = 'chat-message-content';
            contentDiv.innerHTML = '<span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span>';
            
            typingDiv.appendChild(contentDiv);
            chatMessages.appendChild(typingDiv);
            chatMessages.scrollTop = chatMessages.scrollHeight;
            
            return typingDiv.id;
        }

        function removeTypingIndicator(id) {
            const typingDiv = document.getElementById(id);
            if (typingDiv) {
                typingDiv.remove();
            }
        }

        // Focus on chat input when page loads with book info
        if (chatInput) {
            chatInput.focus();
        }
    </script>
<% } %>

<% if (!bookInfo && !error && searchQuery === '') { %>
    <div class="welcome-message">
        <i class="fas fa-book-open"></i>
        <p>Explore the world of literature</p>
    </div>
<% } %>
