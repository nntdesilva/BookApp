{
  "name": "gateway",
  "version": "1.0.0",
  "description": "API Gateway - serves frontend views and proxies to backend services",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon --ext js,ejs,css app.js",
    "test": "jest --verbose",
    "test:ci": "jest --verbose --ci"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "ejs-mate": "^4.0.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
