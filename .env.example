# ============================================================
# Microservices Architecture - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# For Docker Compose, these values are shared across services.
# For local development, each service reads its own .env file.
# ============================================================

# --- Shared Secrets ---
JWT_SECRET=your-jwt-secret-change-in-production

# --- AI API Keys (REQUIRED) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_EMBEDDINGS_API_KEY=your_openai_api_key_here

# --- Claude Model Settings ---
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_TEMPERATURE=0.7
CLAUDE_MAX_TOKENS=4096

# --- Embedding Settings ---
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_SIMILARITY_THRESHOLD=0.48

# --- Conversation Settings ---
MAX_HISTORY_MESSAGES=15

# --- Service Ports (defaults shown) ---
# GATEWAY_PORT=3000
# AUTH_SERVICE_PORT=3001
# FAVORITES_SERVICE_PORT=3002
# BOOKS_SERVICE_PORT=3003
# ANALYSIS_SERVICE_PORT=3004
# CHAT_SERVICE_PORT=3005
# MCP_SERVER_PORT=3006

# --- MongoDB URIs (per-service databases) ---
# Used when running locally without Docker Compose
# AUTH_MONGODB_URI=mongodb://127.0.0.1:27017/bookapp_auth
# FAVORITES_MONGODB_URI=mongodb://127.0.0.1:27017/bookapp_favorites

# --- Redis ---
# REDIS_URL=redis://127.0.0.1:6379

# --- Service URLs (for local dev without Docker Compose) ---
# AUTH_SERVICE_URL=http://localhost:3001
# FAVORITES_SERVICE_URL=http://localhost:3002
# BOOKS_SERVICE_URL=http://localhost:3003
# ANALYSIS_SERVICE_URL=http://localhost:3004
# CHAT_SERVICE_URL=http://localhost:3005

# --- Gutenberg ---
# GUTENBERG_API_URL=https://gutendex.com

# --- MCP Server ---
# MCP_TRANSPORT=http
# MCP_USER_ID=
# MCP_API_KEY=
