# Anthropic Claude Configuration (REQUIRED)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MongoDB Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/bookapp

# Server Configuration
PORT=3000
NODE_ENV=development

# Session Configuration
# Generate a secure random string for production
SESSION_SECRET=your-secret-key-change-in-production

# Claude Model Settings
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_TEMPERATURE=0.7
CLAUDE_MAX_TOKENS=4096

# Conversation Settings
MAX_HISTORY_MESSAGES=15

# OpenAI Embeddings (used ONLY for semantic word search)
OPENAI_EMBEDDINGS_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_SIMILARITY_THRESHOLD=0.48
