{
  "name": "bookapp",
  "version": "2.0.0",
  "description": "A book search and analysis app - Microservices Architecture",
  "private": true,
  "scripts": {
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "install:all": "cd auth-service && npm install && cd ../favorites-service && npm install && cd ../books-service && npm install && cd ../analysis-service && npm install && cd ../chat-service && npm install && cd ../gateway && npm install && cd ../mcp-server && npm install",
    "dev:auth": "cd auth-service && npm run dev",
    "dev:favorites": "cd favorites-service && npm run dev",
    "dev:books": "cd books-service && npm run dev",
    "dev:analysis": "cd analysis-service && npm run dev",
    "dev:chat": "cd chat-service && npm run dev",
    "dev:gateway": "cd gateway && npm run dev",
    "dev:mcp": "cd mcp-server && npm start",
    "prepare": "husky"
  },
  "keywords": [
    "express",
    "claude",
    "anthropic",
    "books",
    "microservices"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "husky": "^9.1.7"
  }
}
